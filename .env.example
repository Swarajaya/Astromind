# AstroMind Environment Configuration
# Copy this file to .env and fill in your values

# ── NASA APIs ────────────────────────────────────────────────
# Free key at https://api.nasa.gov
NASA_API_KEY=your_nasa_api_key_here

# JPL APIs — no key needed (public)
JPL_SBDB_URL=https://ssd-api.jpl.nasa.gov/sbdb.api
JPL_HORIZONS_URL=https://ssd.jpl.nasa.gov/api/horizons.api

# ── Quantum Backend ──────────────────────────────────────────
# Options: aer_simulator (local), ibmq_qasm_simulator (IBM cloud)
QUANTUM_BACKEND=aer_simulator

# IBM Quantum token — leave blank to use local Aer simulator
IBM_QUANTUM_TOKEN=

# ── Simulation Settings ──────────────────────────────────────
MONTE_CARLO_RUNS=1000
PROPAGATION_DAYS=365
VQC_QUBITS=8
VQC_LAYERS=2

# ── Server ───────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
